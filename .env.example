# Database configuration (for MySQL with docker-compose)
DATABASE_VERSION=8.0
DATABASE_ROOT_PASSWORD=rootpassword
DATABASE_NAME=daadnegar
DATABASE_USER=daadnegar
DATABASE_PASSWORD=daadnegar_secret
DATABASE_HOST=127.0.0.1
# Use 3307 when connecting from host (Docker forwards host:3307 -> container:3306)
DATABASE_PORT=3307
DATABASE_FORWARD_PORT=3307
# Replace with actual values - .env doesn't support ${VAR} expansion
DATABASE_URL="mysql://daadnegar:daadnegar_secret@127.0.0.1:3307/daadnegar"

# BetterAuth configuration
BETTER_AUTH_SECRET="SECRET_KEY_HERE"
BETTER_AUTH_URL="http://localhost:3000"

# Seed (pnpm prisma:seed) — اولین ادمین با نام کاربری پیش‌فرض admin
# SEED_FIRST_USER_USERNAME=admin
# در صورت تنظیم SEED_FIRST_USER_EMAIL، همان به‌جای ایمیل داخلی ساخته‌شده از نام کاربری استفاده می‌شود
# SEED_FIRST_USER_EMAIL=

# MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=daadnegar-uploads

# RabbitMQ (run: docker compose up -d, then pnpm worker in another terminal)
RABBITMQ_URL=amqp://guest:guest@localhost:5672
