// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// Better Auth - Core schema (https://www.better-auth.com/docs/concepts/database)
model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("user") // "user" | "validator"
  tokenBalance  Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions        Session[]
  accounts        Account[]
  reports         Report[]
  assignedReports Report[] @relation("ReportAssignedTo")
  auditLogs       AuditLog[]
  admin           Admin?
  inviteSessions     InviteSession[]
  usedInviteCodes    InviteCode[]
  createdInviteCodes InviteCode[] @relation("InviteCodeInviter")
  tokenTransactions  TokenTransaction[]
}

/** Event-sourcing: هر تغییر توکن ثبت می‌شود. tokenBalance در User فقط cache است. */
model TokenTransaction {
  id        String   @id @default(cuid())
  userId    String
  amount    Int      // مثبت = واریز، منفی = برداشت
  type      String   // registration | report_approved | report_false | report_problematic | invite_activity
  refId     String?  // مثلاً reportId برای تراکنش‌های مربوط به گزارش
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("token_transaction")
}

model Session {
  id         String   @id @default(cuid())
  userId     String
  token      String   @unique
  expiresAt  DateTime
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// --- daadnegar domain models ---

model Admin {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admin")
}

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String
  description String?
  type        String   @default("report")
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  parentId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent                 Category?   @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children               Category[]  @relation("CategoryHierarchy")
  reportsAsCategory      Report[]    @relation("ReportCategory")
  reportsAsSubcategory   Report[]    @relation("ReportSubcategory")

  @@unique([slug, type, parentId])
  @@index([type])
  @@index([parentId])
  @@map("category")
}

model Person {
  id           String    @id @default(cuid())
  firstName    String
  lastName     String
  fatherName   String?   // نام پدر
  nationalCode String?
  imageUrl     String?
  title        String?   // سمت
  organization String?   // ارگان
  dateOfBirth  DateTime?
  address      String?
  mobile       String?
  phone        String?
  isFamous     Boolean   @default(false)
  status       String    @default("approved") // approved | pending - pending: در انتظار تایید ادمین
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  reports Report[]

  @@index([isFamous])
  @@index([status])
  @@map("person")
}

model Province {
  id        String   @id @default(cuid())
  name      String   @unique
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  cities City[]

  @@map("province")
}

model City {
  id         String   @id @default(cuid())
  name       String
  provinceId String
  sortOrder  Int      @default(0)
  createdAt DateTime @default(now())

  province Province @relation(fields: [provinceId], references: [id], onDelete: Cascade)

  @@unique([name, provinceId])
  @@index([provinceId])
  @@map("city")
}

model Report {
  id               String    @id @default(cuid())
  userId           String
  personId         String
  categoryId       String?
  subcategoryId    String?
  title            String?
  description      String @db.Text
  organizationType String?
  organizationName String?
  province         String?
  city             String?
  exactLocation    String?
  occurrenceFrequency String?
  occurrenceDate   DateTime?
  hasEvidence      Boolean?
  evidenceTypes    String?
  evidenceDescription String?
  wantsContact     Boolean?
  contactEmail     String?
  contactPhone     String?
  contactSocial    String?
  status           String    @default("pending")
  assignedTo       String?   // Validator userId - round-robin assigned for validator queue
  rejectionReason  String?   // "false" | "problematic" when status=rejected
  reviewedBy       String?
  reviewedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedToUser User?  @relation("ReportAssignedTo", fields: [assignedTo], references: [id], onDelete: SetNull)
  person      Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  category    Category? @relation("ReportCategory", fields: [categoryId], references: [id], onDelete: SetNull)
  subcategory Category? @relation("ReportSubcategory", fields: [subcategoryId], references: [id], onDelete: SetNull)
  documents   ReportDocument[]
  reviews     ReportReview[]

  @@index([userId])
  @@index([status])
  @@map("report")
}

/** بررسی‌های گزارش: تایید/رد توسط اعتبارسنج یا ادمین */
model ReportReview {
  id             String   @id @default(cuid())
  reportId       String
  reviewerId     String?   // User.id for validators; null for admin panel users
  action         String    // "accepted" | "rejected"
  rejectionReason String?  // "problematic" | "false" when action=rejected; problematic=نقص/افشا، false=گزارش اشتباه/قصد تخریب
  createdAt      DateTime @default(now())

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@map("report_review")
}

model ReportDocument {
  id        String   @id @default(cuid())
  reportId  String
  name      String
  url       String
  createdAt DateTime @default(now())

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@map("report_document")
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  entity     String
  entityId   String?
  userId     String?
  details    String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entity])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_log")
}

model InviteCode {
  id           String   @id @default(cuid())
  code         String   @unique
  isActive     Boolean  @default(true)
  usedById     String?  // one code = one person; set when user registers
  inviterId    String?  // for user-created invites; null = seed codes (e.g. DEMO456)
  invitedEmail String?  // for personal invites - who we're inviting
  createdAt    DateTime @default(now())

  inviter  User?     @relation("InviteCodeInviter", fields: [inviterId], references: [id], onDelete: SetNull)
  usedBy   User?     @relation(fields: [usedById], references: [id], onDelete: SetNull)
  sessions InviteSession[]

  @@index([usedById])
  @@index([inviterId])
  @@map("invite_code")
}

model InviteSession {
  id           String    @id @default(cuid())
  token        String    @unique
  inviteCodeId String
  passkeyHash  String?
  userId       String?
  expiresAt    DateTime
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  inviteCode InviteCode @relation(fields: [inviteCodeId], references: [id], onDelete: Cascade)
  user       User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([token])
  @@index([inviteCodeId])
  @@map("invite_session")
}

// Admin panel - separate auth (IP whitelist + username/password)
model AdminPanelUser {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  sessions AdminPanelSession[]

  @@map("admin_panel_user")
}

model AdminPanelIpWhitelist {
  id        String   @id @default(cuid())
  ipAddress String   // exact IP or CIDR (e.g. 192.168.1.0/24)
  createdAt DateTime @default(now())

  @@map("admin_panel_ip_whitelist")
}

model AdminPanelSession {
  id               String   @id @default(cuid())
  adminPanelUserId String
  token            String   @unique
  expiresAt        DateTime
  ipAddress        String?
  createdAt        DateTime @default(now())

  adminPanelUser AdminPanelUser @relation(fields: [adminPanelUserId], references: [id], onDelete: Cascade)

  @@index([adminPanelUserId])
  @@map("admin_panel_session")
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   // stored as JSON string for flexibility
  updatedAt DateTime @updatedAt

  @@map("setting")
}
