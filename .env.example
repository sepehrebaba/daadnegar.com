# Database configuration (for MySQL with docker-compose)
DATABASE_VERSION=8.0
DATABASE_ROOT_PASSWORD=rootpassword
DATABASE_NAME=dadban
DATABASE_USER=dadban
DATABASE_PASSWORD=dadban_secret
DATABASE_HOST=127.0.0.1
# Use 3307 when connecting from host (Docker forwards host:3307 -> container:3306)
DATABASE_PORT=3307
DATABASE_FORWARD_PORT=3307
# Replace with actual values - .env doesn't support ${VAR} expansion
DATABASE_URL="mysql://dadban:dadban_secret@127.0.0.1:3307/dadban"

BETTER_AUTH_SECRET="SECRET_KEY_HERE"
BETTER_AUTH_URL="http://localhost:3000"

# MinIO (آپلود امن فایل با حذف متادیتا)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=dadban-uploads