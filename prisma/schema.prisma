// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

// Better Auth - Core schema (https://www.better-auth.com/docs/concepts/database)
model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions        Session[]
  accounts        Account[]
  invitationsSent AppInvitation[]
  reports        Report[]
  auditLogs       AuditLog[]
  admin           Admin?
}

model Session {
  id         String   @id @default(cuid())
  userId     String
  token      String   @unique
  expiresAt  DateTime
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model AppInvitation {
  id              String    @id @default(cuid())
  name            String?
  email           String?
  inviterId       String
  status          String
  domainWhitelist String?
  expiresAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  inviter User @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@map("appInvitation")
}

// --- Dadban domain models ---

model Admin {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admin")
}

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String
  description String?
  type        String   @default("report")
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  parentId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent                 Category?   @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children               Category[]  @relation("CategoryHierarchy")
  reportsAsCategory      Report[]    @relation("ReportCategory")
  reportsAsSubcategory   Report[]    @relation("ReportSubcategory")

  @@unique([slug, type, parentId])
  @@index([type])
  @@index([parentId])
  @@map("category")
}

model Person {
  id           String   @id @default(cuid())
  firstName    String
  lastName     String
  nationalCode String?
  imageUrl     String?
  title        String?
  isFamous     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  reports Report[]

  @@index([isFamous])
  @@map("person")
}

model Province {
  id        String   @id @default(cuid())
  name      String   @unique
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  cities City[]

  @@map("province")
}

model City {
  id         String   @id @default(cuid())
  name       String
  provinceId String
  sortOrder  Int      @default(0)
  createdAt DateTime @default(now())

  province Province @relation(fields: [provinceId], references: [id], onDelete: Cascade)

  @@unique([name, provinceId])
  @@index([provinceId])
  @@map("city")
}

model Report {
  id                   String    @id @default(cuid())
  userId               String
  personId             String
  categoryId           String?
  subcategoryId        String?
  title                String?
  description          String
  organizationType    String?
  organizationName    String?
  province             String?
  city                 String?
  exactLocation        String?
  occurrenceFrequency  String?
  occurrenceDate       DateTime?
  hasEvidence          Boolean?
  evidenceTypes       String?
  evidenceDescription  String?
  wantsContact         Boolean?
  contactEmail         String?
  contactPhone         String?
  contactSocial        String?
  status               String    @default("pending")
  reviewedBy           String?
  reviewedAt           DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  person      Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  category    Category? @relation("ReportCategory", fields: [categoryId], references: [id], onDelete: SetNull)
  subcategory Category? @relation("ReportSubcategory", fields: [subcategoryId], references: [id], onDelete: SetNull)
  documents   ReportDocument[]

  @@index([userId])
  @@index([status])
  @@map("report")
}

model ReportDocument {
  id        String   @id @default(cuid())
  reportId  String
  name      String
  url       String
  createdAt DateTime @default(now())

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@map("report_document")
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  entity     String
  entityId   String?
  userId     String?
  details    String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entity])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_log")
}

model InviteCode {
  id        String   @id @default(cuid())
  code      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("invite_code")
}
